# App public origin (절대 URL, 후행 슬래시 없음). 공유/OG URL + allowed-origin 검사에 사용.
# Production: Vercel 에 실제 도메인 설정. 미설정 시 VERCEL_PROJECT_PRODUCTION_URL 로 fallback.
NEXT_PUBLIC_APP_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Local Supabase Google OAuth provider only. Do not commit real values.
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
# Local Supabase Kakao OAuth provider + KakaoTalk Share. Do not commit real values.
SUPABASE_AUTH_EXTERNAL_KAKAO_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_KAKAO_SECRET=
NEXT_PUBLIC_KAKAO_JAVASCRIPT_KEY=
KAKAO_ADMIN_KEY=
# C-7 RLS 통합 테스트용 (Supabase Auth 에 미리 생성된 테스트 사용자 2명)
TEST_SUPABASE_USER_A_EMAIL=
TEST_SUPABASE_USER_A_PASSWORD=
TEST_SUPABASE_USER_B_EMAIL=
TEST_SUPABASE_USER_B_PASSWORD=

# OpenAI (ZDR Enterprise required)
OPENAI_API_KEY=
OPENAI_PROJECT_ID=

# Anthropic (fallback only)
ANTHROPIC_API_KEY=

# KASI 천문연
KASI_API_KEY=

# Toss Payments (Phase 1)
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
# Temporary legacy aliases accepted by the app while environments are migrated.
TOSS_PAYMENTS_CLIENT_KEY=
TOSS_PAYMENTS_SECRET_KEY=

# Observability
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# LLM cost cap
LLM_DAILY_BUDGET_USD=20

# TWA (Phase 0 G5+)
BUBBLEWRAP_KEYSTORE_PATH=
BUBBLEWRAP_KEYSTORE_PASSWORD=

# G2 / Phase 3 — 오늘카드 인연 종합 (today + relation 3축).
# 기본 켜기 (미설정 또는 'true' 시 활성). 문제 발생 시 'false' 로 즉시 단독 today 로 복귀.
# false → /api/today 가 relation-picker 호출 생략 + 단독 daily_hap 프롬프트 사용 + relation 필드 미주입.
NEXT_PUBLIC_TODAY_WITH_RELATION=true
